generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Task {
  id          String   @id
  title       String
  description String
  year        Int
  completed   Boolean  @default(false)
  priority    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
